                autoplay muted loop playsinline disablepictureinpicture
                width="112" height="175"
                style="display:none;object-fit:cover;object-position:center;border-radius:5px;border:1px solid #d7d7d9;padding:2px;margin-right:5px">
            </video>
        </a>
        <h3>
            <a class="js-banner-ai-list-title-link" href="#" title="" target="_blank" rel="nofollow">
                <span class="js-banner-ai-list-title"></span>
            </a>
        </h3>

        
        <a class="list-story-item-wrap-chapter _098cc7f8 js-banner-ai-list-subtitle"
            title="" href="#" target="_blank" rel="nofollow"></a>

        
        <div><span class="aye_icon js-banner-ai-list-view"></span></div> <br><br>

        
        <div class="js-banner-ai-list-desc-wrap" style="display:none;">
            <p class="js-banner-ai-list-desc"> </p>
            <div class="read-more-wrap">
                <a class="read-more _098cc7f8 js-banner-ai-list-link" href="#" rel="nofollow" target="_blank">Read more</a>
            </div>
