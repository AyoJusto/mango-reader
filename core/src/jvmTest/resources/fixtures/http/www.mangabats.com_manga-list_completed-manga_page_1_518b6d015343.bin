    </div>

    <script>
        (function () {
            var banners = [{"title":"Jenny Sato - Your AI Girlfriend","sub_title":"Advertisement","view":"4.928.389","url":"https:\/\/bit.ly\/3QZAlLr","asset":"\/images\/bns\/common\/jenny-sato-thumb.png","type":"image","desc":"From San Francisco, California. Just an energetic social work student with too much Jennergy, a camera always in hand, and a tendency to talk in Jennyese while accidentally creating Jentastrophes - but hey, that\u0027s just me being Jenny!","rel":"nofollow"}];
            if (!banners || !banners.length) return;

            // Pick a random.
            var banner = banners[Math.floor(Math.random() * banners.length)];

            var root = document.getElementById('js-banner-ai-list-6a528028edf69');
            if (!root) return;

            var url = banner.url || '#';
            var rel = banner.rel || 'nofollow';
            var title = banner.title || '';

            // Links (cover image + read-more share the same hook).
            var links = root.querySelectorAll('.js-banner-ai-list-link');
            for (var l = 0; l < links.length; l++) {
                links[l].href = url;
                links[l].setAttribute('rel', rel);
            }

            // Title link + text.
            var titleLink = root.querySelector('.js-banner-ai-list-title-link');
            if (titleLink) {
                titleLink.href = url;
                titleLink.title = title;
                titleLink.setAttribute('rel', rel);
            }
            var titleEl = root.querySelector('.js-banner-ai-list-title');
            if (titleEl) titleEl.textContent = title;

            // Sub-title row.
            var subtitle = root.querySelector('.js-banner-ai-list-subtitle');
            if (subtitle) {
                subtitle.textContent = banner.sub_title || '';
                subtitle.title = banner.sub_title || '';
                subtitle.href = url;
                subtitle.setAttribute('rel', rel);
            }

            // Views.
            var viewEl = root.querySelector('.js-banner-ai-list-view');
            if (viewEl) viewEl.textContent = banner.view || '';

            // Optional description block.
            if (banner.desc) {
                var descEl = root.querySelector('.js-banner-ai-list-desc');
                if (descEl) descEl.textContent = banner.desc;
                var descWrap = root.querySelector('.js-banner-ai-list-desc-wrap');
                if (descWrap) descWrap.style.display = '';
            }

            // Media: show image or video depending on the banner type.
            var img = root.querySelector('.js-banner-ai-list-img');
            var video = root.querySelector('.js-banner-ai-list-video');
            if (banner.type === 'video') {
                if (img) img.style.display = 'none';
                if (video && banner.asset) {
                    video.src = banner.asset;
                    try { video.load(); } catch (e) {}
                    video.style.display = '';
                }
            } else {
                if (video) video.style.display = 'none';
                if (img && banner.asset) {
                    img.src = banner.asset;
                    img.setAttribute('data-src', banner.asset);
                    img.alt = title;
                    img.style.display = '';
                }
            }

            root.hidden = false;
        })();
    </script>
 
                    
                    
                                            
