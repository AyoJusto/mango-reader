                function updateTime() {
                    const now = new Date();
                    const formattedTime = now.toLocaleDateString('en-US', {
                        year: 'numeric',
                        month: 'short',
                        day: 'numeric',
                        hour: 'numeric',
                        minute: 'numeric',
                        second: 'numeric',
                        hour12: true,
                    });
                    document.getElementById('current-time').textContent = formattedTime;
                }
                setInterval(updateTime, 1000);
                updateTime(); // initial call to display time immediately
            </script>
