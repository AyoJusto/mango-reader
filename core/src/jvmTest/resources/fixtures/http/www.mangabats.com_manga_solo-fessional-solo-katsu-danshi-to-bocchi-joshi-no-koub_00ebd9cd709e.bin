                    <svg width="20" height="14" viewBox="0 0 20 14" fill="none"
    xmlns="http://www.w3.org/2000/svg">
    <path
        d="M17.6087 5.21124C18.575 6.22797 18.575 7.77268 17.6087 8.78941C15.9788 10.5042 13.1797 12.8337 10.0001 12.8337C6.82049 12.8337 4.02133 10.5042 2.3915 8.78941C1.42516 7.77268 1.42516 6.22797 2.3915 5.21124C4.02132 3.49644 6.82048 1.16699 10.0001 1.16699C13.1797 1.16699 15.9788 3.49644 17.6087 5.21124Z"
        stroke="#111111" stroke-width="1.5" />
    <path
        d="M12.5001 7.00033C12.5001 8.38104 11.3808 9.50033 10.0001 9.50033C8.61937 9.50033 7.50008 8.38104 7.50008 7.00033C7.50008 5.61961 8.61937 4.50033 10.0001 4.50033C11.3808 4.50033 12.5001 5.61961 12.5001 7.00033Z"
        stroke="#111111" stroke-width="1.5" />
</svg>                    <span>Hide comment</span>
                </button>
                <button class="ban-comment-btn" onclick="banUserFromCommenting(event, '')">
                    <svg width="18" height="20" viewBox="0 0 18 20" fill="none"
    xmlns="http://www.w3.org/2000/svg">
    <path
        d="M9 17.5C12.866 17.5 16 14.366 16 10.5C16 6.63401 12.866 3.5 9 3.5C5.13401 3.5 2 6.63401 2 10.5C2 14.366 5.13401 17.5 9 17.5Z"
        stroke="#111111" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    <path
        d="M5.5 10.5H12.5"
        stroke="#111111" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    <path
        d="M9 6V15"
        stroke="#111111" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
</svg>
                    <span>Ban Comment</span>
                </button>
                <button class="ban-user-btn" onclick="banUserFromSystem(event, '')">
                    <svg width="18" height="20" viewBox="0 0 18 20" fill="none"
    xmlns="http://www.w3.org/2000/svg">
    <circle cx="9" cy="7" r="4" stroke="#111111" stroke-width="1.5"/>
    <path
        d="M2 17C2 13.6863 4.68629 11 8 11H10C13.3137 11 16 13.6863 16 17"
        stroke="#111111" stroke-width="1.5" stroke-linecap="round"/>
    <path
