        stroke="#DC2626" stroke-width="1.5" stroke-linecap="round"/>
</svg>
                    <span>Ban User</span>
                </button>
                <button class="report-btn" onclick="openReportModal(event, '')" data-comment-id="''">
                    <svg width="18" height="20" viewBox="0 0 18 20" fill="none"
    xmlns="http://www.w3.org/2000/svg">
    <path
        d="M1.5 18.3337V11.667M1.5 11.667V2.50033M1.5 11.667H4.83333M1.5 2.50033V1.66699M1.5 2.50033H11.5C12.4205 2.50033 13.1667 3.24652 13.1667 4.16699V5.83366M13.1667 5.83366H14.8333C15.7538 5.83366 16.5 6.57985 16.5 7.50033V14.167C16.5 15.0875 15.7538 15.8337 14.8333 15.8337H6.5C5.57953 15.8337 4.83333 15.0875 4.83333 14.167V11.667M13.1667 5.83366V10.0003C13.1667 10.9208 12.4205 11.667 11.5 11.667H4.83333"
        stroke="#111111" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
</svg>                    <span>Report</span>
                </button>
                <button class="delete-btn" onclick="deleteComment(event, '')">
                    <svg width="10" height="10" viewBox="0 0 10 10" fill="none"
    xmlns="http://www.w3.org/2000/svg">
    <path d="M8.53567 1.46489L1.4646 8.53595M8.53567 8.53591L1.4646 1.46484" stroke="#ED3849"
        stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
</svg>                    <span>Delete</span>
                </button>
            </div>
        </div>
    </div>
</div>
</div>
