    </div>

    <div id="reportModal" class="modal-overlay hidden" onclick="onModalOverlayClick(event)">
    <div class="modal-content" onclick="event.stopPropagation()">
        <div style="font-weight: 600; margin-bottom: 12px">Report Comment</div>
        <input type="hidden" id="report-comment-id" value="comment.id" />

        <label for="report-type" style="font-size: 14px; margin-bottom: 16px; display: block">
            Please select the reason you want to report this comment:        </label>

        <ul class="report-options">
            <li>
                <label>
                    <input class="radio-input" type="radio" name="report-type" value="spam" onclick="onReportTypeChange(this)" />
                    Spam or advertisement                </label>
            </li>
            <li>
                <label>
                    <input class="radio-input" type="radio" name="report-type" value="offensive" onclick="onReportTypeChange(this)" />
                    Offensive / hateful language                </label>
            </li>
            <li>
                <label>
                    <input class="radio-input" type="radio" name="report-type" value="spoiler" onclick="onReportTypeChange(this)" />
                    Spoiler                </label>
            </li>
            <li>
                <label>
                    <input class="radio-input" type="radio" name="report-type" value="personal_attack" onclick="onReportTypeChange(this)" />
                    Harassment or personal attack                </label>
            </li>
            <li>
                <label>
                    <input class="radio-input" type="radio" name="report-type" value="sensitive_comment" onclick="onReportTypeChange(this)" />
                    Sensitive or inappropriate content                </label>
            </li>
            <li>
                <label>
                    <input class="radio-input" type="radio" name="report-type" value="other" onclick="onReportTypeChange(this)" />
                    Other                </label>
            </li>
            <li id="other-reason-container" style="display: none;">
                <textarea id="report-reason" rows="2" placeholder="Other (please specify...)"></textarea>
            </li>
        </ul>

        <div class="modal-actions">
            <button class="btn cancel-btn" onclick="closeReportModal()">Cancel</button>
            <button class="btn report-btn" onclick="submitReport()">Submit</button>
        </div>
    </div>
</div>

<script src="https://www.mangabats.com/js/report.js?v2.0.2"></script>
</div>

<!-- Ban Modal -->
<div id="ban-modal" class="ban-modal" style="display: none;">
    <div class="ban-modal-backdrop" onclick="closeBanModal()"></div>
    <div class="ban-modal-content">
        <div class="ban-modal-header">
            <h3 id="ban-modal-title">Ban User</h3>
            <button class="ban-modal-close" onclick="closeBanModal()">&times;</button>
        </div>
        <div class="ban-modal-body">
            <p id="ban-modal-message"></p>
            <div class="form-group">
                <label for="ban-days">Days (0 for permanent):</label>
                <input type="number" id="ban-days" class="form-control" min="0" value="7">
            </div>
            <div class="form-group" style="margin-top: 16px;">
                <label style="display: flex; align-items: center; gap: 8px; cursor: pointer;">
                    <input type="checkbox" id="ban-delete-all-comments" style="width: auto; margin: 0;">
                    <span>Delete all comments from this user</span>
                </label>
            </div>
        </div>
        <div class="ban-modal-footer">
            <button class="btn btn-secondary" onclick="closeBanModal()">Cancel</button>
            <button class="btn btn-danger" id="ban-confirm-btn">Ban User</button>
        </div>
    </div>
</div>

<!-- Confirm Modal -->
<div id="confirm-modal" class="ban-modal" style="display: none;">
    <div class="ban-modal-backdrop" onclick="closeConfirmModal()"></div>
    <div class="ban-modal-content">
        <div class="ban-modal-header">
            <h3 id="confirm-modal-title">Confirm</h3>
            <button class="ban-modal-close" onclick="closeConfirmModal()">&times;</button>
        </div>
        <div class="ban-modal-body">
            <p id="confirm-modal-message"></p>
        </div>
        <div class="ban-modal-footer">
            <button class="btn btn-secondary" onclick="closeConfirmModal()">Cancel</button>
            <button class="btn btn-danger" id="confirm-modal-confirm-btn">Confirm</button>
        </div>
    </div>
</div>


<script src="https://www.mangabats.com/js/comment.js?v2.0.5"></script>
<script src="https://www.mangabats.com/js/editor.js?v2.0.4"></script>
