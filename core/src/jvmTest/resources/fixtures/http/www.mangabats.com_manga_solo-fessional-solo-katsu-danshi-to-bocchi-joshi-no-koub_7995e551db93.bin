    <script>
         $(document).on('click', '#btnBookmarkChapter', function () {
            $btn = $(this);
            const url = $(this).data('url');
            if (!url) {
                return;
            }
            const action = $(this).data('action');
            showLoadingButton();

            $.ajax({
                type: "GET",
                url: url,
                data: {
                    action: action,
                },
                success: function (response) {
                    if (response.success) {
                        showFollowedButton();
                        localStorage.removeItem('bookmarkBadgeCount');
                    }
                },
                error: function(xhr, status, error) {
                    if (xhr.status == 401) {
                        $('body').append(htmlNotification);
                    } else{
                        console.error("AJAX Error: ", error);
                    }
                    showBookmarkButton();
                }
            });
        });
        function getMangeStatus() {
            if (Auth.isAuthenticated()) {
                $.ajax({
                    url: $mangaStatusUrl,
                    type: 'GET',
                    success: function (response) {
                        if (response.success && response.data['isBookmarked'] === 1) {
                            showFollowedButton();
                        } else {
                            showBookmarkButton();
                        }
                    },
                    error: function(xhr, status, error) {
                        showBookmarkButton();
                    }
                });
            } else {
                showBookmarkButton();
            }
        }
        $(document).ready(function() {
            getMangeStatus();
        });

        function showFollowedButton() {
            const bookmarkContainer = $('#btnBookmarkChapter');
            bookmarkContainer.empty();
            bookmarkContainer.removeAttr('data-url');
            bookmarkContainer.removeAttr('id');
            bookmarkContainer.append('<a href="/bookmark" style="color: #059e9a !important;display: inline-block;"> Followed </a>');
        }

        function showBookmarkButton() {
            const bookmarkContainer = $('#btnBookmarkChapter');
            bookmarkContainer.empty();
            bookmarkContainer.attr('data-url', "https://www.mangabats.com/action/bookmark/75302");
            bookmarkContainer.attr('data-action', 'add');
            bookmarkContainer.css('cursor', 'pointer');
            bookmarkContainer.append('🌟 Bookmark');
        }

        function showLoadingButton() {
            const bookmarkContainer = $('#btnBookmarkChapter');
            bookmarkContainer.empty();
            bookmarkContainer.removeAttr('data-url');
            bookmarkContainer.append('<img src="/images/loadingimg.gif" style="height: 6px;" />');
        }
    </script>

    <script type="application/javascript">
        document.querySelectorAll('.pn-op-sv-img-btn').forEach(button => {
            button.addEventListener('click', function() {
                if (this.classList.contains('isactive')) return;
                document.querySelectorAll('.pn-op-sv-img-btn').forEach(btn => btn.classList.remove('isactive'));
                this.classList.add('isactive');
                const selectedCdn = this.getAttribute('data-cdn');
                const imgContainer = document.querySelector('.container-chapter-reader');
                imgContainer.innerHTML = '';
                chapterImages.forEach((img, index) => {
                    const imgElement = document.createElement('img');
                    imgElement.src = [cdns[selectedCdn-1].trim().replace(/^\/+/, ''), img.trim().replace(/\/+$/, '')].join('/');
                    imgElement.alt = `Solo-fessional: Solo Katsu Danshi to Bocchi Joshi no Koubou-sen Chapter 2 page  ${index + 1}  - Mangabat`;
                    imgElement.title = imgElement.alt;
                    // imgElement.onerror = function() {
                    //     this.onerror = null;
                    //     this.src = [backupImage[selectedCdn-1].trim().replace(/^\/+/, ''), img.trim().replace(/\/+$/, '')].join('/');
                    // };
                    imgElement.loading = 'lazy';
                    if (index === Math.floor(chapterImages.length / 2)) {
                        imgElement.id = 'image-scroll-trigger';
                    }
                    imgContainer.appendChild(imgElement);
                });
            });
        });
    </script>

    
    <script type="application/javascript">
        window.addEventListener('load', function() {
            const imageContainer = document.querySelector('.container-chapter-reader');
            const distanceToTop = imageContainer.getBoundingClientRect().top + window.scrollY;

            const adsSidebarLeft = document.querySelector('#adsSidebarLeft');
            const adsSidebarLeftHeight = adsSidebarLeft ? adsSidebarLeft.offsetHeight : 0;
            const adsSidebarLeftWidth = adsSidebarLeft ? adsSidebarLeft.offsetWidth : 0;

            const firstImage = imageContainer.querySelector('img');
            const firstImageMarginLeft = parseFloat(window.getComputedStyle(firstImage).marginLeft);

            if (adsSidebarLeftHeight > distanceToTop && firstImageMarginLeft < adsSidebarLeftWidth) {
                imageContainer.style.paddingTop = `${adsSidebarLeftHeight - distanceToTop}px`;
            }
        });
    </script>
    
            

