-- Library + read progress. Timestamps are epoch millis.

CREATE TABLE library_item (
  source_id TEXT NOT NULL,
  manga_id TEXT NOT NULL,
  title TEXT NOT NULL,
  cover TEXT,
  added_at INTEGER NOT NULL,
  chapter_count INTEGER NOT NULL DEFAULT 0,
  last_opened_at INTEGER NOT NULL DEFAULT 0,
  PRIMARY KEY (source_id, manga_id)
);

CREATE TABLE read_progress (
  source_id TEXT NOT NULL,
  manga_id TEXT NOT NULL,
  chapter_id TEXT NOT NULL,
  page INTEGER NOT NULL,
  finished INTEGER NOT NULL DEFAULT 0,
  updated_at INTEGER NOT NULL,
  chapter_number REAL NOT NULL DEFAULT 0,
  PRIMARY KEY (source_id, manga_id, chapter_id)
);

-- unread_count and last_read_at are derived per series: a LEFT JOIN against read_progress means
-- a series with zero progress rows still emits one row (unread_count = chapter_count, last_read_at
-- NULL). A read_progress row counts as "started" regardless of finished, so unread_count only
-- drops once a chapter has been opened at all, never requiring it be finished.
--
-- new_count is a correlated scalar subquery rather than a second join: joining chapter_cache
-- alongside read_progress would multiply rows across both one-to-many relations, corrupting
-- unread_count and last_read_at's aggregates.
selectAllLibraryItems:
SELECT
  li.source_id AS source_id,
  li.manga_id AS manga_id,
  li.title AS title,
  li.cover AS cover,
  li.added_at AS added_at,
  li.chapter_count AS chapter_count,
  MAX(0, li.chapter_count - COUNT(rp.chapter_id)) AS unread_count,
  MAX(rp.updated_at) AS last_read_at,
  (SELECT COUNT(*) FROM chapter_cache cc
    WHERE cc.source_id = li.source_id AND cc.manga_id = li.manga_id
      AND cc.first_seen_at > li.last_opened_at) AS new_count
FROM library_item li
LEFT JOIN read_progress rp ON rp.source_id = li.source_id AND rp.manga_id = li.manga_id
GROUP BY li.source_id, li.manga_id, li.title, li.cover, li.added_at, li.chapter_count, li.last_opened_at
ORDER BY li.added_at DESC;

-- chapter_count and last_opened_at are preserved via correlated subqueries, not overwritten to 0:
-- addToLibrary is called on every chapter download for a series already in the library (not just
-- the initial add), and an unconditional REPLACE would zero the Library grid's unread and new
-- pills on every download.
upsertLibraryItem:
INSERT OR REPLACE INTO library_item(source_id, manga_id, title, cover, added_at, chapter_count, last_opened_at)
VALUES (
  ?1, ?2, ?3, ?4, ?5,
  COALESCE((SELECT chapter_count FROM library_item WHERE source_id = ?1 AND manga_id = ?2), 0),
  COALESCE((SELECT last_opened_at FROM library_item WHERE source_id = ?1 AND manga_id = ?2), 0)
);

deleteLibraryItem:
DELETE FROM library_item WHERE source_id = ? AND manga_id = ?;

updateChapterCount:
UPDATE library_item SET chapter_count = ? WHERE source_id = ? AND manga_id = ?;

markOpened:
UPDATE library_item SET last_opened_at = ? WHERE source_id = ? AND manga_id = ?;

selectProgress:
SELECT * FROM read_progress WHERE source_id = ? AND manga_id = ? AND chapter_id = ?;

upsertProgress:
INSERT INTO read_progress(source_id, manga_id, chapter_id, page, finished, updated_at, chapter_number)
VALUES (?, ?, ?, ?, ?, ?, ?)
ON CONFLICT(source_id, manga_id, chapter_id) DO UPDATE SET
  page = excluded.page,
  finished = MAX(read_progress.finished, excluded.finished),
  updated_at = excluded.updated_at,
  chapter_number = excluded.chapter_number;

selectFinishedChapterIds:
SELECT chapter_id FROM read_progress WHERE source_id = ? AND manga_id = ? AND finished = 1;

selectLatestProgress:
SELECT * FROM read_progress WHERE source_id = ? AND manga_id = ? ORDER BY updated_at DESC LIMIT 1;
