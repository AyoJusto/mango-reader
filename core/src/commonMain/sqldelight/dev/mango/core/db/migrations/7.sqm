-- v7 -> v8: collections (see collections.sq for table notes). Upgraders get the default shelf
-- seeded here; fresh databases self-heal it on first library filing instead.

CREATE TABLE collection (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  name TEXT NOT NULL UNIQUE,
  position INTEGER NOT NULL,
  is_default INTEGER NOT NULL DEFAULT 0
);

CREATE TABLE collection_member (
  collection_id INTEGER NOT NULL,
  source_id TEXT NOT NULL,
  manga_id TEXT NOT NULL,
  PRIMARY KEY (collection_id, source_id, manga_id)
);

INSERT INTO collection(name, position, is_default) VALUES ('Reading', 0, 1);
